rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) 
        && data.keys().size() <= 7
        && data.uid == request.auth.uid
        && data.email is string
        && data.role in ['customer', 'admin']
        && (data.get('displayName', '') is string)
        && (data.get('photoURL', '') is string);
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'slug', 'price', 'category', 'stock_quantity'])
        && data.name is string && data.name.size() <= 200
        && data.slug is string && data.slug.size() <= 200
        && data.price is number && data.price >= 0
        && data.category is string
        && data.stock_quantity is int && data.stock_quantity >= 0;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'totalAmount', 'status', 'paymentMethod', 'shippingDetails'])
        && data.userId == request.auth.uid
        && data.totalAmount is number && data.totalAmount >= 0
        && data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled']
        && data.items is list && data.items.size() <= 50
        && data.paymentMethod is string
        && data.shippingDetails is map
        && data.shippingDetails.keys().hasAll(['fullName', 'phone', 'address', 'city', 'district'])
        && data.shippingDetails.fullName is string && data.shippingDetails.fullName.size() <= 200
        && data.shippingDetails.phone is string && data.shippingDetails.phone.size() <= 200
        && data.shippingDetails.address is string && data.shippingDetails.address.size() <= 500
        && data.shippingDetails.city is string && data.shippingDetails.city.size() <= 100
        && data.shippingDetails.district is string && data.shippingDetails.district.size() <= 100;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['productId', 'userId', 'rating', 'comment', 'createdAt'])
        && data.productId is string
        && data.userId == request.auth.uid
        && data.rating is number && data.rating >= 1 && data.rating <= 5
        && data.comment is string && data.comment.size() <= 1000
        && data.createdAt == request.time;
    }

    // --- Collection Rules ---

    // Users
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'customer';
      allow update: if isOwner(userId) && isValidUser(incoming()) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL'])
        || isAdmin();
    }

    // Admins list (Read-only for rules)
    match /admins/{adminId} {
      allow read: if isSignedIn();
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Carts
    match /carts/{userId} {
      allow get, write: if isOwner(userId);
    }

    // Wishlists
    match /wishlists/{userId} {
      allow get, write: if isOwner(userId);
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidReview(incoming());
      allow update: if isOwner(existing().userId) && isValidReview(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'comment']);
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow get: if isOwner(existing().userId) || isAdmin();
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidOrder(incoming()) && incoming().userId == request.auth.uid;
      allow update: if isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status']);
    }
  }
}
